# .env.example — copie para .env e preencha os valores reais

# PostgreSQL — ex: Neon, Supabase, Railway ou local
DATABASE_URL="postgresql://usuario:senha@localhost:5432/wisekm_db"

# NextAuth v5 — gere com: openssl rand -base64 32
AUTH_SECRET="sua_chave_secreta_super_forte_aqui"

# URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"
