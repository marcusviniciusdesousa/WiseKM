// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  cpf       String   @unique
  email     String   @unique
  senha     String   // bcrypt hash — NUNCA armazenar plain text
  criadoEm DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Relações futuras (ex: veículos, despesas)
  // veiculo Veiculo[]

  @@map("usuarios")
}

// ──────────────────────────────────────────────────────────────
// Tabela de sessões para NextAuth v5 (Database Strategy)
// ──────────────────────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
